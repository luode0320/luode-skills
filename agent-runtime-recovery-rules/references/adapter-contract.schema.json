{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime-recovery.invalid/schemas/adapter-contract.schema.json",
  "title": "Agent Runtime Recovery Adapter Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapter_id", "platform_id", "version", "components", "operations", "limits"],
  "properties": {
    "adapter_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "platform_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "version": {"type": "string", "minLength": 1, "maxLength": 64},
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "component_kind", "scope", "capability_level", "idempotency_classes"],
        "properties": {
          "component_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "component_kind": {"enum": ["mcp", "plugin", "browser", "tool", "agent_host", "other"]},
          "scope": {"type": "string", "minLength": 1, "maxLength": 256},
          "capability_level": {"type": "integer", "minimum": 0, "maximum": 5},
          "capabilities": {"type": "array", "items": {"enum": ["probe", "reconnect", "reload", "restart", "wait_ready", "checkpoint", "resume"]}, "uniqueItems": true},
          "idempotency_classes": {"type": "array", "minItems": 1, "items": {"enum": ["read_only", "idempotent", "idempotent_with_key", "non_idempotent"]}, "uniqueItems": true},
          "side_effects": {"type": "array", "items": {"type": "string", "maxLength": 256}},
          "authorization": {"type": "string", "minLength": 1, "maxLength": 512},
          "rollback": {"type": "string", "minLength": 1, "maxLength": 512},
          "fingerprint_strategy": {"type": "string", "minLength": 1, "maxLength": 256}
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["probe", "reconnect", "reload", "restart", "wait_ready"],
      "properties": {
        "probe": {"$ref": "#/$defs/operation"},
        "reconnect": {"$ref": "#/$defs/operation"},
        "reload": {"$ref": "#/$defs/operation"},
        "restart": {"$ref": "#/$defs/operation"},
        "wait_ready": {"$ref": "#/$defs/operation"},
        "checkpoint": {"$ref": "#/$defs/operation"},
        "resume": {"$ref": "#/$defs/operation"}
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_probe_attempts", "max_retries_per_level", "cooldown_seconds", "lock_ttl_seconds"],
      "properties": {
        "max_probe_attempts": {"type": "integer", "minimum": 1, "maximum": 1},
        "max_retries_per_level": {"type": "integer", "minimum": 1, "maximum": 1},
        "cooldown_seconds": {"type": "integer", "minimum": 1},
        "lock_ttl_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "checkpoint_policy": {"$ref": "#/$defs/checkpoint"}
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported", "entrypoint", "success_criteria"],
      "properties": {
        "supported": {"type": "boolean"},
        "entrypoint": {"type": "string", "minLength": 1, "maxLength": 512},
        "success_criteria": {"type": "string", "minLength": 1, "maxLength": 512},
        "side_effects": {"type": "array", "items": {"type": "string", "maxLength": 256}}
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "ttl_seconds", "fields", "redaction_version"],
      "properties": {
        "enabled": {"type": "boolean"},
        "ttl_seconds": {"type": "integer", "minimum": 1},
        "redaction_version": {"type": "string", "minLength": 1, "maxLength": 32},
        "fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["recovery_id", "task_id_hash", "platform_id", "adapter_id", "component_id", "component_kind", "scope_hash", "failure_class", "request_digest", "idempotency_class", "original_success_criterion", "workspace_fingerprint", "attempt_budget", "cooldown_seconds", "lock_key", "created_at", "expires_at", "resume_token_digest"]}
        }
      }
    }
  }
}
