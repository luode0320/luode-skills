{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "scope", "source_order", "policies", "tools"],
  "properties": {
    "schema_version": {"const": 2},
    "scope": {"const": "windows-user"},
    "source_order": {"type": "array", "items": {"enum": ["winget", "scoop-existing", "chocolatey-existing"]}, "uniqueItems": true},
    "policies": {"type": "object"},
    "tools": {"type": "array", "minItems": 1}
  }
}
